---
interface Props {
	title?: string;
}
const { title = "Happy 21st Birthday, Kayla Putri Sabrina" } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Selamat ulang tahun ke-21 untuk Kayla Putri Sabrina — a special birthday surprise just for you." />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link
			href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&family=Quicksand:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--cream: #efe6da;
		--cream-2: #f6f0e6;
		--ink: #2e2118;
		--ink-soft: #5c4d40;
		--pink: #f1567b;
		--pink-soft: #ffc9d6;
		--blue: #b7c9e6;
		--gold: #f0b429;
		--shadow: #c9b8a3;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html,
	body {
		height: 100%;
		overscroll-behavior: none;
	}

	body {
		font-family: 'Quicksand', sans-serif;
		background: var(--cream);
		color: var(--ink);
		overflow: hidden;
	}

	h1,
	h2,
	.script {
		font-family: 'Caveat', cursive;
	}
</style>
