---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Happy 21st Birthday, Kayla Putri Sabrina 🎂",
	description = "Selamat ulang tahun ke-21, Kayla Putri Sabrina! Kejutan spesial untukmu di hari paling istimewa ini 💖",
} = Astro.props;

// Absolute URL untuk OG image (wajib untuk WhatsApp preview)
const siteUrl = Astro.site ?? new URL(Astro.request.url).origin;
const ogImage = new URL('/og-image.jpg', siteUrl).href;
const pageUrl  = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- ── Favicon (foto Kayla) ── -->
		<link rel="icon" type="image/jpeg" href="/favicon.jpg" />
		<link rel="apple-touch-icon" href="/favicon.jpg" />

		<!-- ── Primary meta ── -->
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>

		<!-- ── Open Graph (WhatsApp, Facebook, Telegram) ── -->
		<meta property="og:type"        content="website" />
		<meta property="og:url"         content={pageUrl} />
		<meta property="og:title"       content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image"       content={ogImage} />
		<meta property="og:image:width"  content="800" />
		<meta property="og:image:height" content="800" />
		<meta property="og:image:alt"   content="Foto ulang tahun Kayla Putri Sabrina" />
		<meta property="og:locale"      content="id_ID" />
		<meta property="og:site_name"   content="Happy 21st Birthday Kayla 🎂" />

		<!-- ── Twitter Card (WhatsApp juga kadang baca ini) ── -->
		<meta name="twitter:card"        content="summary_large_image" />
		<meta name="twitter:title"       content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image"       content={ogImage} />

		<!-- ── Fonts ── -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link
			href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&family=Quicksand:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--cream: #efe6da;
		--cream-2: #f6f0e6;
		--ink: #2e2118;
		--ink-soft: #5c4d40;
		--pink: #f1567b;
		--pink-soft: #ffc9d6;
		--blue: #b7c9e6;
		--gold: #f0b429;
		--shadow: #c9b8a3;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html,
	body {
		height: 100%;
		overscroll-behavior: none;
	}

	body {
		font-family: 'Quicksand', sans-serif;
		background: var(--cream);
		color: var(--ink);
		overflow: hidden;
	}

	h1,
	h2,
	.script {
		font-family: 'Caveat', cursive;
	}
</style>
