<script>
	/* ---------- Section nav (horizontal slider) ---------- */
	const slider = document.getElementById('slider') as HTMLElement;
	const sections = [...document.querySelectorAll < HTMLElement > ('.section')];
	const dots = [...document.querySelectorAll < HTMLButtonElement > ('#dots button')];
	const prevBtn = document.getElementById('prevBtn') as HTMLElement;
	const nextBtn = document.getElementById('nextBtn') as HTMLElement;
	let current = 0;

	function goTo(i: number) {
		i = Math.max(0, Math.min(sections.length - 1, i));
		sections[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
	}
	dots.forEach(btn => btn.addEventListener('click', () => goTo(+(btn.dataset.i ?? 0))));
	prevBtn.addEventListener('click', () => goTo(current - 1));
	nextBtn.addEventListener('click', () => goTo(current + 1));

	const letterCard = document.getElementById('letterCard') as HTMLElement;

	function setActive(i: number) {
		current = i;
		dots.forEach(d => d.classList.remove('active'));
		dots[i].classList.add('active');
		prevBtn.toggleAttribute('disabled', i === 0);
		nextBtn.toggleAttribute('disabled', i === sections.length - 1);
		// Trigger entrance animation — never removed so content stays visible once revealed
		sections[i].classList.add('is-active');
		if (sections[i].id === 's2') letterCard.classList.add('show');
	}

	const obs = new IntersectionObserver((entries) => {
		entries.forEach(e => {
			if (e.isIntersecting && e.intersectionRatio > .6) {
				setActive(sections.indexOf(e.target as HTMLElement));
			}
		});
	}, { root: slider, threshold: .6 });
	sections.forEach(s => obs.observe(s));
	// Reveal first slide immediately — avoids invisible-content flash before observer fires
	sections[0].classList.add('is-active');

	/* convert vertical mouse-wheel to horizontal slide */
	slider.addEventListener('wheel', (e) => {
		if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
			e.preventDefault();
			slider.scrollLeft += e.deltaY;
		}
	}, { passive: false });

	/* keyboard arrows */
	window.addEventListener('keydown', (e) => {
		if (e.key === 'ArrowRight') goTo(current + 1);
		if (e.key === 'ArrowLeft') goTo(current - 1);
	});

	/* ---------- Countdown to birthday (29 Juli) ---------- */
	const cdTarget = new Date('2026-07-29T00:00:00');
	// const cdTarget = new Date('2026-07-16T00:00:00');
	let cdCelebrated = false;
	function updateCountdown() {
		const now = new Date();
		let diff = cdTarget.getTime() - now.getTime();
		const sub = document.getElementById('cdSub') as HTMLElement;
		const grid = document.getElementById('countdownGrid') as HTMLElement;
		const burst = document.getElementById('cdBurst') as HTMLElement;
		if (diff <= 0) {
			(document.getElementById('cdDays') as HTMLElement).textContent = '00';
			(document.getElementById('cdHours') as HTMLElement).textContent = '00';
			(document.getElementById('cdMinutes') as HTMLElement).textContent = '00';
			(document.getElementById('cdSeconds') as HTMLElement).textContent = '00';
			if (!cdCelebrated) {
				cdCelebrated = true;
				grid.classList.add('cd-finished');
				sub.textContent = "It's her birthday today! 🎉🎂";
				sub.classList.add('cd-celebrate');
				burst.classList.add('show');
				launchConfetti();
			}
			return;
		}
		const d = Math.floor(diff / 86400000);
		const h = Math.floor(diff % 86400000 / 3600000);
		const m = Math.floor(diff % 3600000 / 60000);
		const s = Math.floor(diff % 60000 / 1000);
		(document.getElementById('cdDays') as HTMLElement).textContent = String(d).padStart(2, '0');
		(document.getElementById('cdHours') as HTMLElement).textContent = String(h).padStart(2, '0');
		(document.getElementById('cdMinutes') as HTMLElement).textContent = String(m).padStart(2, '0');
		(document.getElementById('cdSeconds') as HTMLElement).textContent = String(s).padStart(2, '0');
	}
	updateCountdown();
	setInterval(updateCountdown, 1000);

	/* ---------- Floating hearts/sparkles background ---------- */
	const floaters = document.getElementById('floaters') as HTMLElement;
	const emojis = ['💗', '✨', '☁️', '💫', '🩷'];
	for (let i = 0; i < 18; i++) {
		const s = document.createElement('span');
		s.textContent = emojis[Math.floor(Math.random() * emojis.length)];
		s.style.left = Math.random() * 100 + 'vw';
		s.style.animationDuration = (14 + Math.random() * 12) + 's';
		s.style.animationDelay = (-Math.random() * 20) + 's';
		s.style.fontSize = (14 + Math.random() * 16) + 'px';
		floaters.appendChild(s);
	}

	/* ---------- Envelope open ---------- */
	const envelope = document.getElementById('envelope') as HTMLElement;
	envelope.addEventListener('click', () => {
		envelope.classList.add('open');
		startMusic();
		setTimeout(() => goTo(2), 700);
	});

	/* ---------- Cake blow / click ---------- */
	const cakeWrap = document.getElementById('cakeWrap') as HTMLElement;
	const flame = document.getElementById('flame') as SVGElement;
	const blownMsg = document.getElementById('blownMsg') as HTMLElement;
	let blown = false;
	cakeWrap.addEventListener('click', () => {
		if (blown) return;
		blown = true;
		(flame as HTMLElement).style.transition = 'opacity .4s, transform .4s';
		(flame as HTMLElement).style.opacity = '0';
		(flame as HTMLElement).style.transform = 'scaleY(.2)';
		blownMsg.classList.add('show');
		launchConfetti();
	});

	/* ---------- Confetti ---------- */
	function launchConfetti() {
		const colors = ['#f1567b', '#f0b429', '#b7c9e6', '#ffc9d6', '#2e2118'];
		for (let i = 0; i < 60; i++) {
			const c = document.createElement('div');
			c.className = 'confetti';
			c.style.left = Math.random() * 100 + 'vw';
			c.style.width = c.style.height = (6 + Math.random() * 6) + 'px';
			c.style.background = colors[Math.floor(Math.random() * colors.length)];
			c.style.transform = `rotate(${Math.random() * 360}deg)`;
			document.body.appendChild(c);
			const duration = 2200 + Math.random() * 1800;
			c.animate([
				{ transform: `translateY(0) rotate(0deg)`, opacity: '1' },
				{ transform: `translateY(100vh) rotate(${360 + Math.random() * 360}deg)`, opacity: '.9' }
			], { duration, easing: 'ease-in' });
			setTimeout(() => c.remove(), duration);
		}
	}

</script>

<script is:inline>
	/* ---------- BGM: HTML5 Audio (tidak diblokir ad blocker) ---------- */
	var bgMusic    = document.getElementById('bgMusic');
	var musicBtn   = document.getElementById('musicBtn');
	var musicInfo  = document.getElementById('musicInfo');
	var musicStarted = false;
	var musicPlaying = false;

	bgMusic.volume = 0.6;

	function showInfo()  { musicInfo.classList.add('show'); }
	function hideInfo()  { musicInfo.classList.remove('show'); }

	function startMusic() {
		if (musicStarted) return;
		musicStarted = true;
		var playPromise = bgMusic.play();
		if (playPromise !== undefined) {
			playPromise.then(function () {
				musicPlaying = true;
				musicBtn.classList.add('spinning');
				showInfo();
			}).catch(function () {
				// Autoplay blocked — tunggu interaksi berikutnya
				musicStarted = false;
			});
		}
	}

	function toggleMusic() {
		if (!musicStarted) {
			startMusic();
			return;
		}
		if (musicPlaying) {
			bgMusic.pause();
			musicPlaying = false;
			musicBtn.classList.remove('spinning');
			hideInfo();
		} else {
			bgMusic.play();
			musicPlaying = true;
			musicBtn.classList.add('spinning');
			showInfo();
		}
	}

	// Mulai musik saat interaksi pertama user
	['click', 'touchstart', 'keydown'].forEach(function (evt) {
		document.addEventListener(evt, startMusic, { once: true, passive: true });
	});

	musicBtn.addEventListener('click', function (e) {
		e.stopPropagation(); // jangan trigger startMusic dua kali
		toggleMusic();
	});
</script>