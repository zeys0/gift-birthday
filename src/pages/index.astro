		font-weight: 700;
	}

	.memory-text p {
		margin-top: 1.2vh;
		line-height: 1.8;
		color: var(--ink-soft);
	}

	/* NUMBER */
	.number-row {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6vw;
		flex-wrap: wrap;
	}

	.big21 {
		font-size: clamp(6rem, 18vw, 11rem);
