	.number-text {
		max-width: 360px;
		text-align: left;
	}

	.number-text h2 {
		font-size: 2.4rem;
	}

	.number-text p {
		margin-top: 1.2vh;
		line-height: 1.8;
		color: var(--ink-soft);
