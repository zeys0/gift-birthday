	.level-up {
		margin-top: 1vh;
		font-weight: 700;
		letter-spacing: 1px;
		font-size: .9rem;
		text-transform: uppercase;
	}

	/* REASONS */
	.reasons-list {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.6vh 5vw;
		text-align: left;
		max-width: 760px;
