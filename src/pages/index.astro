---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Happy 21st Birthday, Kayla Putri Sabrina">

	<!-- Floating decor -->
	<div class="floaters" id="floaters"></div>

	<!-- Music toggle + info pill -->
	<div class="music-bar" id="musicBar">
		<div class="music-btn" id="musicBtn" title="Play/Pause musik">
			<svg viewBox="0 0 100 70" width="28" height="20">
				<rect x="2" y="2" width="96" height="66" rx="10" fill="var(--ink)" />
				<rect x="8" y="8" width="84" height="54" rx="6" fill="var(--cream-2)" />
				<circle class="reel" cx="32" cy="34" r="13" fill="none" stroke="var(--ink)" stroke-width="3"
					stroke-dasharray="3 5" />
				<circle cx="32" cy="34" r="4" fill="var(--ink)" />
				<circle class="reel" cx="68" cy="34" r="13" fill="none" stroke="var(--ink)" stroke-width="3"
					stroke-dasharray="3 5" />
				<circle cx="68" cy="34" r="4" fill="var(--ink)" />
				<rect x="18" y="50" width="64" height="7" rx="2.5" fill="var(--pink)" />
			</svg>
		</div>
		<!-- Info pill: muncul saat musik play -->
		<div class="music-info" id="musicInfo">
			<div class="music-notes" aria-hidden="true">
				<span class="note n1">♪</span>
				<span class="note n2">♫</span>
				<span class="note n3">♪</span>
			</div>
			<div class="music-ticker-wrap">
				<div class="music-ticker" id="musicTicker">
					<span>About You — The 1975&nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp;About You — The 1975&nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp;</span>
				</div>
			</div>
		</div>
	</div>

	<!-- Bottom navigation bar (dots + arrows) -->
	<div class="bottom-nav">
		<div class="arrow-nav prev" id="prevBtn" aria-label="Slide sebelumnya">←</div>
		<div class="dots" id="dots">
			<button data-i="0" class="active" aria-label="Slide 1"></button>
			<button data-i="1" aria-label="Slide 2"></button>
			<button data-i="2" aria-label="Slide 3"></button>
			<button data-i="3" aria-label="Slide 4"></button>
			<button data-i="4" aria-label="Slide 5"></button>
			<button data-i="5" aria-label="Slide 6"></button>
			<button data-i="6" aria-label="Slide 7"></button>
		</div>
		<div class="arrow-nav next" id="nextBtn" aria-label="Slide berikutnya">→</div>
	</div>

	<!-- Horizontal Slider -->
	<div class="slider" id="slider">

		<!-- 0. COUNTDOWN -->
		<section class="section" id="s0">
			<h1 style="font-size:clamp(2rem,5.5vw,3.4rem);">Countdown to Kayla's<br>21st Birthday 🎂</h1>
			<div class="countdown-grid" id="countdownGrid">
				<div class="cd-box">
					<div class="cd-num" id="cdDays">00</div>
					<div class="cd-label">Hari</div>
				</div>
				<div class="cd-box">
					<div class="cd-num" id="cdHours">00</div>
					<div class="cd-label">Jam</div>
				</div>
				<div class="cd-box">
					<div class="cd-num" id="cdMinutes">00</div>
					<div class="cd-label">Menit</div>
				</div>
				<div class="cd-box">
					<div class="cd-num" id="cdSeconds">00</div>
					<div class="cd-label">Detik</div>
				</div>
			</div>
			<p class="cd-sub" id="cdSub">…menuju 29 Juli, hari paling spesial tahun ini ✨</p>
			<div class="cd-emoji-burst" id="cdBurst">
				<span>🎉</span><span>🎂</span><span>💖</span><span>🎈</span><span>✨</span>
			</div>
		</section>

		<!-- 1. HERO -->
		<section class="section" id="s1">
			<h1>Happy 21st Birthday,<br>Kayla Putri Sabrina</h1>
			<div class="envelope-wrap">
				<div class="envelope" id="envelope">
					<div class="flap"></div>
					<div class="heart-seal" id="heartSeal">❤️</div>
				</div>
			</div>
			<p class="caption-hint">"Click the heart to open your gift!"</p>
		</section>

		<!-- 2. LETTER -->
		<section class="section" id="s2">
			<p class="script" style="font-size:1.6rem; margin-bottom:2vh;">Pull out the letter! 💌</p>
			<div class="letter-card" id="letterCard">
				<div class="dear">Dear Kayla Putri Sabrina… ❤️</div>
				<p>Happy 21st Birthday to the person who makes my world brighter! Pada tanggal 29 Juli ini, kamu resmi
					berusia 21 tahun. Kamu adalah definisi dari keajaiban yang nyata. Aku sudah menyiapkan beberapa
					kenangan kecil untukmu di slide berikutnya. Semoga kamu suka!</p>
				<div class="sign">— Rafli 💋</div>
			</div>
		</section>

		<!-- 3. MEMORY -->
		<section class="section" id="s3">
			<div class="memory-row">
				<div class="polaroid-frame">
					<div class="polaroid-grid">
						<div class="polaroid-slot">
							<img src="/images/foto1 (1).jpg" alt="Kenangan bersama Kayla 1" />
						</div>
						<div class="polaroid-slot">
							<img src="/images/foto1 (2).jpg" alt="Kenangan bersama Kayla 2" />
						</div>
						<div class="polaroid-slot">
							<img src="/images/foto1 (3).jpg" alt="Kenangan bersama Kayla 3" />
						</div>
						<div class="polaroid-slot">
							<img src="/images/foto1 (4).jpg" alt="Kenangan bersama Kayla 4" />
						</div>
					</div>
					<div class="label">Where it all started…</div>
				</div>
				<div class="memory-text">
					<div class="tag">Memory #01: The Beginning</div>
					<p><strong>"Your Smile is Viral"</strong><br>Ingat foto ini? Ini adalah saat pertama kali aku sadar
						kalau senyuman kamu itu candu banget. Kayak lagu TikTok yang nggak bisa berhenti diputer di
						kepala aku seharian.</p>
				</div>
			</div>
		</section>

		<!-- 4. BIG NUMBER -->
		<section class="section" id="s4">
			<div class="number-row">
				<div class="big21">21</div>
				<div class="number-text">
					<h2>Happy 21st!</h2>
					<p>Welcome to the adulthood era, Kayla! 21 tahun penuh petualangan, tawa, dan cinta menunggumu di
						depan sana. Aku bangga banget sama semua pencapaian kamu sejauh ini.</p>
					<div class="level-up">Level Up!</div>
				</div>
			</div>
		</section>

		<!-- 5. REASONS -->
		<section class="section" id="s5">
			<h2 class="script" style="font-size:2.4rem;">Reasons Why I Love You…</h2>
			<div class="reasons-list">
				<div><span class="ic">❤️</span> Senyuman manismu</div>
				<div><span class="ic">🫂</span> Kehangatan pelukanmu</div>
				<div><span class="ic">⭐</span> Caramu mendukungku</div>
				<div><span class="ic">✨</span> Keajaiban di matamu</div>
				<div><span class="ic">☁️</span> Ketulusan hatimu</div>
				<div><span class="ic">🎵</span> Suara kamu pas nyanyi</div>
				<div><span class="ic">☀️</span> Tawamu yang nular</div>
				<div><span class="ic">⚡</span> Energi positifmu</div>
				<div><span class="ic">🌙</span> Cara kamu dengerin ceritaku</div>
				<div><span class="ic">😊</span> Muka lucu pas kamu ngambek</div>
				<div style="grid-column:1/-1; font-family:'Caveat',cursive; font-size:1.3rem; color:var(--pink);">…and
					11 more secret reasons! 💕</div>
			</div>
		</section>

		<!-- 6. FINAL -->
		<section class="section" id="s6">
			<div class="cake-wrap" id="cakeWrap" title="Klik untuk tiup lilin">
				<svg class="cake-svg" id="cakeSvg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
					<ellipse cx="100" cy="178" rx="70" ry="10" fill="#e0d3bd" />
					<rect x="35" y="120" width="130" height="50" rx="8" fill="#f1567b" />
					<rect x="35" y="120" width="130" height="12" fill="#ffc9d6" />
					<rect x="45" y="85" width="110" height="42" rx="8" fill="#f0b429" />
					<rect x="45" y="85" width="110" height="10" fill="#ffe1a1" />
					<rect x="55" y="55" width="90" height="36" rx="8" fill="#b7c9e6" />
					<rect x="55" y="55" width="90" height="9" fill="#dbe5f5" />
					<circle cx="70" cy="130" r="4" fill="#fff" />
					<circle cx="100" cy="140" r="4" fill="#fff" />
					<circle cx="130" cy="130" r="4" fill="#fff" />
					<circle cx="80" cy="100" r="4" fill="#fff" />
					<circle cx="120" cy="105" r="4" fill="#fff" />
					<rect x="97" y="35" width="6" height="22" fill="#e0d3bd" />
					<g id="flame">
						<path d="M100 15 C93 24 96 32 100 34 C104 32 107 24 100 15 Z" fill="#f0b429" />
						<path d="M100 22 C97 27 98.5 31 100 32 C101.5 31 103 27 100 22 Z" fill="#f1567b" />
					</g>
				</svg>
			</div>
			<h2>Happy Birthday, Kayla!</h2>
			<p class="wish-line">"Make a wish, my princess…"</p>
			<p class="blown-msg" id="blownMsg">Semoga semua yang kamu harapkan jadi kenyataan. Selamat ulang tahun! 🎂💕
			</p>
		</section>

	</div><!-- /.slider -->

	<!-- HTML5 Audio player untuk BGM — tidak bisa diblokir ad blocker -->
	<audio id="bgMusic" loop preload="auto" style="display:none;">
		<source src="/audio/song.mp3" type="audio/mpeg" />
	</audio>

</Layout>

<style is:global>
	/* horizontal slider */
	.slider {
		display: flex;
		flex-direction: row;
		width: 100vw;
		height: 100vh;
		height: 100dvh;
		overflow-x: auto;
		overflow-y: hidden;
		scroll-snap-type: x mandatory;
		scroll-behavior: smooth;
		-webkit-overflow-scrolling: touch;
	}

	.slider::-webkit-scrollbar {
		display: none;
	}

	.slider {
		scrollbar-width: none;
	}

	.section {
		flex: 0 0 100vw;
		width: 100vw;
		height: 100vh;
		height: 100dvh;
		scroll-snap-align: start;
		scroll-snap-stop: always;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		position: relative;
		padding: 8vh 6vw;
		text-align: center;
		overflow-y: auto;
	}

	/* floating decor */
	.floaters {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 1;
		overflow: hidden;
	}

	.floaters span {
		position: absolute;
		font-size: 22px;
		opacity: .55;
		animation: drift linear infinite;
	}

	@keyframes drift {
		from {
			transform: translateY(110vh) rotate(0deg);
		}

		to {
			transform: translateY(-10vh) rotate(30deg);
		}
	}

	/* bottom nav bar */
	.bottom-nav {
		position: fixed;
		bottom: 20px;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 18px;
		z-index: 50;
		padding: 8px 14px;
		padding-bottom: calc(8px + env(safe-area-inset-bottom));
		background: rgba(246, 240, 230, .85);
		backdrop-filter: blur(6px);
		border: 1.5px solid var(--ink);
		border-radius: 999px;
		box-shadow: 4px 4px 0 var(--shadow);
	}

	.dots {
		display: flex;
		flex-direction: row;
		gap: 11px;
	}

	.dots button {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		border: 1.5px solid var(--ink);
		background: transparent;
		cursor: pointer;
		padding: 0;
		opacity: .5;
		transition: all .25s;
		flex-shrink: 0;
	}

	.dots button.active {
		background: var(--pink);
		border-color: var(--pink);
		opacity: 1;
		transform: scale(1.3);
	}

	/* arrow nav */
	.arrow-nav {
		width: 34px;
		height: 34px;
		border-radius: 50%;
		background: var(--cream);
		border: 1.5px solid var(--ink);
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		font-size: 15px;
		transition: transform .2s, opacity .2s;
		user-select: none;
		flex-shrink: 0;
	}

	.arrow-nav:hover {
		transform: scale(1.1);
	}

	.arrow-nav[disabled] {
		opacity: .25;
		pointer-events: none;
	}

	@media(max-width:400px) {
		.bottom-nav {
			gap: 12px;
			padding: 6px 10px;
		}

		.arrow-nav {
			width: 28px;
			height: 28px;
			font-size: 13px;
		}

		.dots button {
			width: 7px;
			height: 7px;
		}
	}

	@media(max-width:640px) {
		.arrow-nav {
			width: 36px;
			height: 36px;
			font-size: 15px;
		}
	}

	@media(max-height:480px) {
		.bottom-nav {
			bottom: 10px;
			padding: 6px 12px;
		}
	}

	/* COUNTDOWN */
	.countdown-grid {
		display: flex;
		gap: 3vw;
		justify-content: center;
		margin-top: 4vh;
		flex-wrap: wrap;
	}

	.cd-box {
		background: var(--cream-2);
		border: 2.5px solid var(--ink);
		border-radius: 10px;
		box-shadow: 5px 5px 0 var(--shadow);
		width: min(110px, 20vw);
		padding: 2.2vh 0;
		transition: transform .3s, opacity .5s;
	}

	.cd-box .cd-num {
		font-size: clamp(1.8rem, 5vw, 2.8rem);
		font-weight: 700;
		color: var(--pink);
	}

	.cd-box .cd-label {
		font-size: .75rem;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: var(--ink-soft);
		margin-top: .4vh;
	}

	.cd-sub {
		margin-top: 3vh;
		font-family: 'Caveat', cursive;
		font-size: 1.4rem;
		color: var(--ink-soft);
		transition: all .4s;
	}

	.countdown-grid.cd-finished .cd-box {
		animation: cdPulse 1.1s ease-in-out infinite;
		border-color: var(--pink);
	}

	.countdown-grid.cd-finished .cd-box:nth-child(2) {
		animation-delay: .1s;
	}

	.countdown-grid.cd-finished .cd-box:nth-child(3) {
		animation-delay: .2s;
	}

	.countdown-grid.cd-finished .cd-box:nth-child(4) {
		animation-delay: .3s;
	}

	@keyframes cdPulse {

		0%,
		100% {
			transform: translateY(0) scale(1);
		}

		50% {
			transform: translateY(-8px) scale(1.06);
		}
	}

	.cd-sub.cd-celebrate {
		color: var(--pink);
		font-size: 1.9rem;
		font-weight: 700;
		animation: cdPopIn .7s cubic-bezier(.34, 1.56, .64, 1);
	}

	@keyframes cdPopIn {
		0% {
			transform: scale(.4);
			opacity: 0;
		}

		60% {
			transform: scale(1.15);
			opacity: 1;
		}

		100% {
			transform: scale(1);
		}
	}

	.cd-emoji-burst {
		display: flex;
		gap: .4em;
		justify-content: center;
		margin-top: 1.4vh;
		font-size: 1.8rem;
		opacity: 0;
		transform: translateY(10px);
		transition: all .5s ease .2s;
	}

	.cd-emoji-burst.show {
		opacity: 1;
		transform: translateY(0);
	}

	.cd-emoji-burst span {
		display: inline-block;
		animation: cdBounce 1.4s ease-in-out infinite;
	}

	.cd-emoji-burst span:nth-child(2) {
		animation-delay: .15s;
	}

	.cd-emoji-burst span:nth-child(3) {
		animation-delay: .3s;
	}

	.cd-emoji-burst span:nth-child(4) {
		animation-delay: .45s;
	}

	.cd-emoji-burst span:nth-child(5) {
		animation-delay: .6s;
	}

	@keyframes cdBounce {

		0%,
		100% {
			transform: translateY(0);
		}

		50% {
			transform: translateY(-14px);
		}
	}

	@media(max-width:480px) {
		.countdown-grid {
			gap: 2.4vw;
		}

		.cd-box {
			width: min(76px, 21vw);
			padding: 1.6vh 0;
		}

		.cd-sub {
			font-size: 1.15rem;
		}

		.cd-sub.cd-celebrate {
			font-size: 1.5rem;
		}
	}

	/* music bar wrapper */
	.music-bar {
		position: fixed;
		left: 20px;
		top: 20px;
		z-index: 60;
		display: flex;
		align-items: center;
		gap: 10px;
	}

	/* music button */
	.music-btn {
		width: 46px;
		height: 46px;
		border-radius: 50%;
		background: var(--cream-2);
		border: 1.5px solid var(--ink);
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		font-size: 18px;
		box-shadow: 3px 3px 0 var(--shadow);
		transition: transform .2s;
		flex-shrink: 0;
	}

	.music-btn:hover { transform: scale(1.08); }

	.music-btn svg { display: block; }

	.music-btn .reel {
		transform-origin: center;
		transform-box: fill-box;
	}

	.music-btn.spinning .reel {
		animation: reelSpin 1.4s linear infinite;
	}

	@keyframes reelSpin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	/* music info pill */
	.music-info {
		display: flex;
		align-items: center;
		gap: 7px;
		background: rgba(246, 240, 230, .88);
		backdrop-filter: blur(8px);
		border: 1.5px solid var(--ink);
		border-radius: 999px;
		padding: 6px 14px 6px 10px;
		box-shadow: 3px 3px 0 var(--shadow);
		max-width: 0;
		overflow: hidden;
		opacity: 0;
		transition: max-width .5s cubic-bezier(.34,1.4,.64,1), opacity .4s ease, padding .5s;
		padding-left: 0;
		padding-right: 0;
		white-space: nowrap;
		pointer-events: none;
	}

	.music-info.show {
		max-width: 220px;
		opacity: 1;
		padding: 6px 14px 6px 10px;
		pointer-events: auto;
	}

	/* bouncing music notes */
	.music-notes {
		display: flex;
		align-items: flex-end;
		gap: 2px;
		height: 20px;
		flex-shrink: 0;
	}

	.note {
		display: inline-block;
		font-size: 13px;
		color: var(--pink);
		animation: noteBounce 1s ease-in-out infinite;
		line-height: 1;
	}
	.note.n1 { animation-delay: 0s; }
	.note.n2 { animation-delay: .18s; font-size: 15px; }
	.note.n3 { animation-delay: .36s; }

	@keyframes noteBounce {
		0%, 100% { transform: translateY(0); opacity: .6; }
		50% { transform: translateY(-6px); opacity: 1; }
	}

	/* scrolling ticker */
	.music-ticker-wrap {
		overflow: hidden;
		max-width: 140px;
	}

	.music-ticker {
		display: inline-flex;
		animation: ticker 8s linear infinite;
		white-space: nowrap;
	}

	.music-ticker span {
		font-family: 'Quicksand', sans-serif;
		font-size: .72rem;
		font-weight: 600;
		color: var(--ink);
		letter-spacing: .3px;
	}

	@keyframes ticker {
		0%   { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}

	@media(max-width: 400px) {
		.music-info.show { max-width: 160px; }
		.music-ticker-wrap { max-width: 100px; }
	}
	/* HERO */
	#s1 h1 {
		font-size: clamp(2.2rem, 6vw, 4.2rem);
		line-height: 1.15;
		font-weight: 700;
	}

	.envelope-wrap {
		margin: 5vh 0 2vh;
	}

	.envelope {
		width: min(360px, 80vw);
		height: min(240px, 55vw);
		background: var(--cream-2);
		border: 2.5px solid var(--ink);
		border-radius: 10px;
		position: relative;
		box-shadow: 6px 6px 0 var(--shadow);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.envelope .flap {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 52%;
		background: var(--blue);
		clip-path: polygon(0 0, 100% 0, 50% 100%);
		border-bottom: 2.5px solid var(--ink);
		transition: transform .6s cubic-bezier(.6, -0.2, .3, 1.4);
		transform-origin: top;
		z-index: 3;
	}

	.envelope.open .flap {
		transform: rotateX(180deg);
	}

	.heart-seal {
		position: absolute;
		top: 38%;
		left: 50%;
		transform: translate(-50%, -50%);
		font-size: 2.6rem;
		z-index: 5;
		filter: drop-shadow(2px 3px 0 rgba(0, 0, 0, .15));
		transition: transform .3s;
	}

	.envelope:hover .heart-seal {
		transform: translate(-50%, -50%) scale(1.15);
	}

	.caption-hint {
		margin-top: 2.2vh;
		font-family: 'Caveat', cursive;
		font-size: 1.4rem;
		color: var(--ink-soft);
	}

	/* LETTER */
	.letter-card {
		max-width: 640px;
		width: 90vw;
		background: var(--cream-2);
		border: 2.5px solid var(--ink);
		border-radius: 6px;
		box-shadow: 8px 8px 0 var(--shadow);
		padding: 6vh 5vw;
		opacity: 0;
		transform: translateY(40px) scale(.96);
		transition: all .8s cubic-bezier(.2, .9, .3, 1.2);
	}

	.letter-card.show {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	.letter-card .dear {
		font-size: 1.7rem;
		font-family: 'Caveat', cursive;
		font-weight: 700;
	}

	.letter-card p {
		margin-top: 2.2vh;
		line-height: 1.85;
		font-size: 1.05rem;
		color: var(--ink-soft);
	}

	.letter-card .sign {
		margin-top: 3vh;
		font-family: 'Caveat', cursive;
		font-size: 1.5rem;
		text-align: right;
	}

	/* MEMORY */
	.memory-row {
		display: flex;
		gap: 6vw;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		max-width: 900px;
	}

	.polaroid-frame {
		width: min(300px, 80vw);
		background: var(--cream-2);
		border: 2.5px solid var(--ink);
		border-radius: 6px;
		padding: 14px 14px 40px;
		box-shadow: 6px 6px 0 var(--shadow);
		transform: rotate(-3deg);
	}

	.polaroid-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 10px;
	}

	.polaroid-slot {
		aspect-ratio: 1/1;
		background: repeating-linear-gradient(45deg, #e7dccb, #e7dccb 6px, #ddd0ba 6px, #ddd0ba 12px);
		border: 1.5px dashed var(--ink-soft);
		border-radius: 3px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.4rem;
		overflow: hidden;
	}

	.polaroid-slot img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.polaroid-frame .label {
		text-align: center;
		margin-top: 14px;
		font-family: 'Caveat', cursive;
		font-size: 1.2rem;
	}

	.memory-text {
		max-width: 340px;
		text-align: left;
